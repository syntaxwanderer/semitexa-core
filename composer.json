{
    "name": "semitexa/core",
    "description": "Semitexa Core - framework runtime, console tooling, and composer integration",
    "version": "v1.1.60",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Semitexa",
            "email": "support@semitexa.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "composer-plugin-api": "^2.0",
        "semitexa/docs": "^1.0",
        "semitexa/tenancy": "^1.0",
        "psr/container": "^2.0",
        "predis/predis": "^2.0",
        "symfony/console": "^7.3",
        "symfony/process": "^7.3"
    },
    "require-dev": {
        "swoole/ide-helper": "^5.1"
    },
    "autoload": {
        "psr-4": {
            "Semitexa\\Core\\": "src/"
        },
        "exclude-from-classmap": [
            "src/PHPStan/"
        ]
    },
    "bin": [
        "bin/semitexa"
    ],
    "extra": {
        "class": "Semitexa\\Core\\Composer\\SemitexaPlugin"
    },
    "keywords": [
        "semitexa",
        "core",
        "runtime",
        "console",
        "composer-plugin"
    ]
}
